{
  "routes": [
    { "src": "/api/lead-respondeu", "dest": "/api/disparo-resposta?type=lead-respondeu" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/proposta/(?<slug>[^/]+)", "dest": "/api/render?tipo=share&slug=$slug" },
    { "src": "/pp/(?<slug>[^/]+)", "dest": "/api/render?tipo=pp&slug=$slug" },
    { "src": "/fiscal/(?<token>[^/]+)", "dest": "/api/fiscal?token=$token" },
    { "src": "/cadastro", "dest": "/api/cadastro" },
    { "src": "/lp/(?<slug>ergometros|box-hibrido|hyrox|crossfit)/?", "dest": "/lp/$slug/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": []
}
